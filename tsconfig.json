{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "moduleResolution": "bundler",
        "rootDir": "src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "playwright-report",
        "test-results"
    ]
}